---
permalink: /patterns.json
---
[
{%- assign cats = site.data.categories | sort: "order" -%}
{%- assign sep = "" -%}
{%- for cat in cats -%}
{%- assign pats = site.patterns | where: "category", cat.key | sort_natural: "title" -%}
{%- for p in pats -%}
{{ sep }}{"title":{{ p.title | jsonify }},"slug":{{ p.slug | jsonify }},"category":{{ cat.title | jsonify }},"categoryKey":{{ cat.key | jsonify }},"summary":{{ p.summary | jsonify }},"adds":{{ p.adds | jsonify }},"prompt":{{ p.prompt | strip_newlines | jsonify }},"url":{{ p.url | absolute_url | jsonify }}}
{%- assign sep = "," -%}
{%- endfor -%}
{%- endfor -%}
]
